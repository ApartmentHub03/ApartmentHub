# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Zoko WhatsApp API (for Supabase Edge Functions)
# These are set in Supabase Function Secrets, not in frontend
# ZOKO_API_KEY=your_zoko_api_key_here
# ZOKO_PHONE_NUMBER=31658975449
# ZOKO_TEMPLATE_NAME=otp_verification
# ZOKO_TEMPLATE_LANG=en

# Get Supabase values from:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and anon/public key

# Get Zoko API key from:
# 1. Go to https://app.live.zoko.io
# 2. Go to More > Webhooks/API
# 3. Copy the API Key
# 4. Add to Supabase Edge Function secrets

# --- MCP dispatch (SEO Develop button) ---
# Base URL of the Mac mini MCP server that hosts the /dispatch/seo-develop endpoint.
# Tailscale IP works: http://100.119.211.126:3100
MCP_DISPATCH_URL=http://100.119.211.126:3100
# A bearer token registered in the MCP server's VALID_TOKENS.
# Use a dedicated token for this integration (e.g. tok_seodispatch:seo-dispatch).
MCP_DISPATCH_TOKEN=tok_seodispatch
