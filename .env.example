# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Zoko WhatsApp API (for Supabase Edge Functions)
# These are set in Supabase Function Secrets, not in frontend
# ZOKO_API_KEY=your_zoko_api_key_here
# ZOKO_PHONE_NUMBER=31658975449
# ZOKO_TEMPLATE_NAME=otp_verification
# ZOKO_TEMPLATE_LANG=en

# Get Supabase values from:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and anon/public key

# Get Zoko API key from:
# 1. Go to https://app.live.zoko.io
# 2. Go to More > Webhooks/API
# 3. Copy the API Key
# 4. Add to Supabase Edge Function secrets

# --- MCP dispatch (SEO Develop button) ---
# Base URL of the Mac mini MCP server that hosts the /dispatch/seo-develop endpoint.
# Tailscale IP works: http://100.119.211.126:3100
MCP_DISPATCH_URL=http://100.119.211.126:3100
# A bearer token registered in the MCP server's VALID_TOKENS.
# Use a dedicated token for this integration (e.g. tok_seodispatch:seo-dispatch).
MCP_DISPATCH_TOKEN=tok_seodispatch

# --- Vercel (SEO Deployment button) ---
# Personal/team Vercel API token (Settings -> Tokens). Server-side only.
VERCEL_TOKEN=vck_xxx
# Either VERCEL_PROJECT_ID (preferred — `prj_...`) or VERCEL_PROJECT_NAME.
# Find the project ID under Project Settings -> General on Vercel.
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=apartmenthub
# Required if the project is owned by a team.
VERCEL_TEAM_ID=
# Branch to look up deployments for (defaults to "seo").
VERCEL_DEPLOY_BRANCH=seo

# --- Salesforce (Apartments list source) ---
# Server-side OAuth client_credentials. Used by /api/salesforce/apartments
# to fetch the live apartment list from Salesforce instead of Supabase.
SALESFORCE_TOKEN_URL=https://apartmenthub--hubdev.sandbox.my.salesforce.com/services/oauth2/token
SALESFORCE_API_URL=https://apartmenthub--hubdev.sandbox.my.salesforce-sites.com/services/apexrest/listofapartments
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# --- GitHub (SEO Merge button) ---
# Personal access token with `repo` scope. Used to look up the open
# `seo -> main` PR, check mergeability, and merge it.
GITHUB_TOKEN=ghp_xxx
# owner/repo, e.g. "akshatbaranwal/ApartmentHub".
GITHUB_REPO=
# Base branch to merge into (defaults to "main").
GITHUB_BASE_BRANCH=main
# Head branch produced by the dispatch jobs (defaults to "seo").
GITHUB_DISPATCH_BRANCH=seo
