# Server
PORT=3100

# Auth — comma-separated list of "token:username" pairs
VALID_TOKENS=tok_akshat:akshat,tok_david:david,tok_user3:user3,tok_user4:user4

# Supabase (service role — shared, for REST API queries)
SUPABASE_URL=https://diovljzaabbfftcqmwub.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Management API (for raw SQL queries)
# Get your access token from: https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=diovljzaabbfftcqmwub
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token

# GitHub
GITHUB_TOKEN=your_github_pat
GITHUB_REPO=your-org/ApartmentHub

# Codebase (path to the cloned repo on the server)
REPO_PATH=/app/repo

# Repo auto-sync (git pull every N ms, default 5min)
REPO_AUTO_SYNC=true
REPO_SYNC_INTERVAL_MS=300000

# Logging
LOG_DIR=/app/logs

# --- SEO "Develop" button dispatch ---
# Spawns a headless `claude -p` session to implement an SEO suggestion
# on the configured branch. The Mac mini must have Claude Code installed
# AND be logged in (Max plan OAuth) via `claude login` at least once.
#
# Path to the claude binary (leave as "claude" if it's on PATH)
CLAUDE_BIN=claude
# Branch that dispatched jobs commit to (never main)
DISPATCH_BRANCH=seo
# Per-job logs (defaults to <LOG_DIR>/dispatch)
# DISPATCH_LOG_DIR=/app/logs/dispatch
