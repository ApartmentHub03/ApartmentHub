# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Zoko WhatsApp API (shared — used in both Edge Functions and Next.js API routes)

# Get Supabase values from:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and anon/public key

# Get Zoko API key from:
# 1. Go to https://app.live.zoko.io
# 2. Go to More > Webhooks/API
# 3. Copy the API Key
# 4. Add to Supabase Edge Function secrets

# --- MCP dispatch (SEO Develop button) ---
# Base URL of the Mac mini MCP server that hosts the /dispatch/seo-develop endpoint.
# Tailscale IP works: http://100.119.211.126:3100
MCP_DISPATCH_URL=http://100.119.211.126:3100
# A bearer token registered in the MCP server's VALID_TOKENS.
# Use a dedicated token for this integration (e.g. tok_seodispatch:seo-dispatch).
MCP_DISPATCH_TOKEN=tok_seodispatch

# --- Vercel (SEO Deployment button) ---
# Personal/team Vercel API token (Settings -> Tokens). Server-side only.
VERCEL_TOKEN=vck_xxx
# Either VERCEL_PROJECT_ID (preferred — `prj_...`) or VERCEL_PROJECT_NAME.
# Find the project ID under Project Settings -> General on Vercel.
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=apartmenthub
# Required if the project is owned by a team.
VERCEL_TEAM_ID=
# Branch to look up deployments for (defaults to "seo").
VERCEL_DEPLOY_BRANCH=seo

# --- Apartments list source ---
# Supabase is the system of record. /api/salesforce/apartments now reads the
# Supabase `apartments` table (status = 'Active') by default. The var below is
# kept ONLY as an emergency rollback hatch — set it to "salesforce" to use the
# legacy path. Leave unset/"supabase" for normal operation.
APARTMENTS_SOURCE=supabase

# --- Salesforce (DEPRECATED — being removed) ---
# Salesforce is no longer the system of record. These vars only feed the legacy
# rollback path of /api/salesforce/apartments and the dossier/docs routes, which
# are being phased out in favour of Supabase. Safe to leave blank.
# SALESFORCE_TOKEN_URL=
# SALESFORCE_API_URL=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=

# --- GitHub (SEO Merge button) ---
# Personal access token with `repo` scope. Used to look up the open
# `seo -> main` PR, check mergeability, and merge it.
GITHUB_TOKEN=ghp_xxx
# owner/repo, e.g. "akshatbaranwal/ApartmentHub".
GITHUB_REPO=
# Base branch to merge into (defaults to "main").
GITHUB_BASE_BRANCH=main
# Head branch produced by the dispatch jobs (defaults to "seo").
GITHUB_DISPATCH_BRANCH=seo

# --- Zoko WhatsApp API ---
ZOKO_API_KEY=your_zoko_api_key_here
# Used in both Edge Functions (set as Supabase secret) and Next.js API routes

# --- Google Places API (dynamic reviews on sell/buy pages) ---
# Server-side only — never expose in browser. Used by /api/google-reviews route handler.
# Enable "Places API" in Google Cloud Console > APIs & Services > Library.
# Create an API key in Credentials and restrict it to Places API + your domains.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
# Public Place ID for ApartmentHub (safe to expose). Find it at:
# https://developers.google.com/maps/documentation/places/web-service/place-id
NEXT_PUBLIC_GOOGLE_PLACE_ID=your_google_place_id_here

# --- Meta Ads Lead Form ---
# Meta Pixel ID (from Facebook Events Manager > Data Sources)
META_PIXEL_ID=your_pixel_id
# Meta Conversions API access token (from Events Manager > Settings)
META_CAPI_ACCESS_TOKEN=your_capi_access_token
# Zoko welcome template IDs for Meta Ads lead follow-up
ZOKO_META_WELCOME_TEMPLATE_NL=welcome_message_from_add
ZOKO_META_WELCOME_TEMPLATE_EN=welcome_message_from_add
ZOKO_META_WELCOME_TEMPLATE_TYPE=template
# Cal.com webhook secret — for HMAC verification of incoming booking webhooks
# Can be left empty during testing; HMAC verification skipped when unset
CALCOM_WEBHOOK_SECRET=
# Google Sheets webhook secret — Bearer token for /api/webhooks/dealsheet
DEALSHEET_WEBHOOK_SECRET=
# Zapier/Make webhook URL — leads are forwarded here until Supabase is set up
# Create a Zap: Catch Hook > Google Sheets Add Row
LEAD_WEBHOOK_URL=

# --- Gmail draft creation (Generate Offer feature) ---
# Dedicated Gmail service account (separate from SEO's GOOGLE_* vars). Requires
# one-time domain-wide delegation in the Google Workspace Admin Console:
#   Admin Console -> Security -> API Controls -> Manage Domain-Wide Delegation
#   Add the service account's Client ID (numeric, from the JSON key) with scope:
#   https://www.googleapis.com/auth/gmail.compose
# Once delegated, any @apartmenthub.nl user can have drafts created on their
# behalf by the Generate Offer route. The logged-in agent's crm_users.email
# is the mailbox the draft lands in.
GMAIL_SERVICE_ACCOUNT_EMAIL=apartmenthub-gmail@your-project.iam.gserviceaccount.com
GMAIL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Falls back to GOOGLE_SERVICE_ACCOUNT_EMAIL / GOOGLE_PRIVATE_KEY if the
# dedicated Gmail vars are unset (legacy deployments sharing the SEO SA).
# Optional: override the allowed email domain (defaults to "apartmenthub.nl").
# GMAIL_DELEGATION_DOMAIN=apartmenthub.nl

# --- Dev Tools: Reset Test Dossier (/crm-admin -> Dev Tools tab) ---
# Comma-separated phone DIGITS (no +, no spaces) that the admin is allowed to
# wipe via the Reset Test Dossier tool. Leave unset to DISABLE the tool entirely
# (every reset attempt returns 403). Only add your own test numbers here, never
# real tenant numbers.
# Example: ALLOWED_RESET_PHONES=31612345678,31687654321
ALLOWED_RESET_PHONES= 639996710543,31683221189
